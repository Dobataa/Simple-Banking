{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ESNext",
    "target": "ES2020",
    "types": ["node"],

    "sourceMap": true,
    "strict": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true
  }
}
